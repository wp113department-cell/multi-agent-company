# ============================================================
# Gridiron Developer Department — .gitignore
# ============================================================

# ------------------------------------------------------------
# Environment & Secrets (NEVER commit these)
# ------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production
.env.staging
secrets/

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
.venv/
venv/
env/
pip-wheel-metadata/
*.egg-info/
.eggs/

# Python tool caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/

# ------------------------------------------------------------
# Node / JavaScript / TypeScript
# ------------------------------------------------------------
node_modules/
.next/
.turbo/
dist/
build/
coverage/

# Playwright E2E
apps/web/test-results/
apps/web/playwright-report/
apps/web/blob-report/

# TypeScript incremental build info (generated, not source)
*.tsbuildinfo
tsconfig.tsbuildinfo

# ------------------------------------------------------------
# OS & Editor
# ------------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ------------------------------------------------------------
# Reference repos (cloned locally for architectural research)
# ------------------------------------------------------------
repos/

# ------------------------------------------------------------
# Runtime artifacts — created at runtime, never commit
# ------------------------------------------------------------
artifacts/
