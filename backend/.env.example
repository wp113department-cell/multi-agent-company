# ============================================================
# Gridiron Developer Department — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE (required)
# ------------------------------------------------------------
# PostgreSQL DSN. asyncpg driver required for async SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://gridiron:gridiron@localhost:5432/gridiron_dev

# ------------------------------------------------------------
# ANTHROPIC API (required)
# ------------------------------------------------------------
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------
# MODEL TIERS (optional — defaults shown)
# ------------------------------------------------------------
# Haiku: router/triage/PM/Architect/Decomposer (cheap, fast)
MODEL_PLANNER=claude-haiku-4-5-20251001
# Sonnet: Coder/QA/Review (best code quality)
MODEL_CODER=claude-sonnet-5
# Haiku: heartbeat/summary/embeddings
MODEL_ROUTER=claude-haiku-4-5-20251001

# ------------------------------------------------------------
# VOYAGE AI (optional — enables semantic search)
# ------------------------------------------------------------
# Get your key at https://www.voyageai.com/
# If unset, context builder falls back to keyword-only scoring.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-code-2
VOYAGE_DIMENSIONS=1536

# ------------------------------------------------------------
# REPOSITORY INTELLIGENCE
# ------------------------------------------------------------
# Absolute path to the codebase agents will read and operate on.
TARGET_REPO_PATH=/home/pc-117/Documents/CRR2906

# Directory where per-task git worktrees are created.
WORKTREES_DIR=/tmp/gridiron-worktrees

# Directory where GitHub repos cloned via the UI are stored.
REPOS_DIR=/tmp/gridiron-repos

# ------------------------------------------------------------
# PIPELINE BEHAVIOUR
# ------------------------------------------------------------
# full  = PM Agent → Architect Agent → Decomposer (LangGraph, Phase 3)
# simple = single Planner Agent (Phase 1 mode, no LangGraph)
PIPELINE_MODE=full

# Max self-correction retries before Coder marks task blocked.
MAX_RETRIES=3

# Token budget for context assembly (used by context_builder).
CONTEXT_TOKEN_BUDGET=8000

# ------------------------------------------------------------
# PHASE 5 — COST CONTROLLER
# ------------------------------------------------------------
# Epics with estimated cost (USD) above this require human approval before agents start.
COST_APPROVAL_THRESHOLD=1.0

# Model pricing per token (USD). Update when Anthropic pricing changes.
COST_PER_INPUT_TOKEN=0.0000008
COST_PER_OUTPUT_TOKEN=0.000004

# Baseline estimation coefficients (used when no historical data exists).
COST_TOKENS_PER_SUBTASK=4000
COST_OUTPUT_RATIO=0.3

# ------------------------------------------------------------
# PHASE 5 — MANAGER AGENT
# ------------------------------------------------------------
# Max retries per subtask before it is counted as blocked.
MANAGER_MAX_SUBTASK_RETRIES=2
# Number of blocked subtasks that triggers epic.halted.
MANAGER_MAX_EPIC_FAILURES=2

# ------------------------------------------------------------
# PHASE 5 — DEVOPS AGENT (read-only bash allowlist)
# ------------------------------------------------------------
# Comma-separated command prefixes the DevOps agent may run.
# Only add safe, read-only commands.
DEVOPS_BASH_ALLOWLIST=git status,git log,git diff,df -h,du -sh,ls,pwd,cat,echo,free -h,uptime

# ------------------------------------------------------------
# PHASE 5 — RBAC
# ------------------------------------------------------------
# Set to false in local dev / tests to skip RBAC enforcement.
RBAC_ENABLED=true

# ------------------------------------------------------------
# PHASE 6 — RESEARCH AGENT
# ------------------------------------------------------------
# Set to false to skip the Research Agent step before planning.
RESEARCH_ENABLED=true

# ------------------------------------------------------------
# PHASE 6 — ENGINEERING MEMORY (pgvector)
# ------------------------------------------------------------
# Set to false to disable task outcome embedding and memory queries.
MEMORY_ENABLED=true
# Number of similar past tasks injected into Architect Agent context.
MEMORY_TOP_K=3

# ------------------------------------------------------------
# PHASE 7 — CONCURRENCY CAPS
# ------------------------------------------------------------
# Max number of epics that can run simultaneously.
MAX_CONCURRENT_EPICS=10
# Max total agent runs across all epics at the same time.
MAX_CONCURRENT_AGENT_RUNS=20
# Max subtasks running simultaneously within a single epic.
MAX_CONCURRENT_SUBTASKS_PER_EPIC=5

# ------------------------------------------------------------
# PHASE 7 — EXECUTIVE AGENT
# ------------------------------------------------------------
# Max number of epics the Executive Agent may create from a single goal.
EXECUTIVE_MAX_EPICS_PER_GOAL=5

# ------------------------------------------------------------
# PHASE 7 — QUEUE BACKEND
# ------------------------------------------------------------
# asyncio (default, in-process) or rq (requires a running Redis + rq worker).
QUEUE_BACKEND=asyncio

# ------------------------------------------------------------
# GAP DAY 4 — REDIS (used by RQ queue and Redis Streams)
# ------------------------------------------------------------
# Redis connection URL. Only needed when QUEUE_BACKEND=rq or REDIS_STREAMS_ENABLED=true.
REDIS_URL=redis://localhost:6379/0

# Set true to publish events to Redis Streams (in addition to in-process bus).
REDIS_STREAMS_ENABLED=false

# Consumer group name for Redis Streams consumers.
REDIS_CONSUMER_GROUP=gridiron-consumers

# ------------------------------------------------------------
# GAP DAY 4 — S3 ARTIFACT STORAGE
# ------------------------------------------------------------
# db (default, PostgreSQL) or s3 (AWS S3).
ARTIFACT_BACKEND=db

# S3 bucket name. Required when ARTIFACT_BACKEND=s3.
S3_BUCKET=

# AWS region for the S3 bucket.
S3_REGION=us-east-1

# Key prefix for artifact objects in the bucket.
S3_KEY_PREFIX=gridiron/artifacts/

# AWS credentials. Leave empty to use IAM role or environment credentials.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Logging level for the FastAPI server (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Comma-separated CORS origins. Add your production frontend URL here.
# Example: https://app.gridiron.example.com,http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ------------------------------------------------------------
# RELIABILITY TUNING
# ------------------------------------------------------------
# Max handler retry attempts in the in-process event bus.
EVENT_BUS_MAX_RETRIES=3

# Max Groq API call retries on transient RateLimitError.
GROQ_MAX_RETRIES=5

# ------------------------------------------------------------
# RATE LIMITING (slowapi)
# ------------------------------------------------------------
# Set false to disable API rate limiting in development.
RATE_LIMIT_ENABLED=true

# Default limit for all endpoints (N/second|minute|hour).
RATE_LIMIT_DEFAULT=200/minute

# Stricter limits for expensive endpoints.
RATE_LIMIT_TASKS=60/minute
RATE_LIMIT_AGENTS=30/minute

# ------------------------------------------------------------
# JWT AUTHENTICATION
# ------------------------------------------------------------
# Generate with: openssl rand -hex 32
# REQUIRED in production when JWT_AUTH_ENABLED=true.
JWT_SECRET_KEY=

# JWT signing algorithm.
JWT_ALGORITHM=HS256

# Access token lifetime in minutes (default: 24 hours).
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set true to enforce JWT Bearer tokens on all RBAC-protected endpoints.
# When false (default), the legacy X-User-Role header is accepted instead.
JWT_AUTH_ENABLED=false

# ------------------------------------------------------------
# FLEET ENHANCEMENT DASHBOARD (Day 9 — 5 self-improvement agents)
# ------------------------------------------------------------
# Root of the Gridiron project itself. These 5 agents (unlike every other agent)
# target this codebase, not a user-connected repo. Defaults to cwd.
FLEET_SELF_REPO_PATH=.

# Hours between automatic SCAN-phase runs (background loop). 0 disables the loop.
FLEET_SCAN_INTERVAL_HOURS=4

# ------------------------------------------------------------
# FLEET OS BUDGET MANAGER (Day 10 — live spend/resource enforcement)
# ------------------------------------------------------------
# Max total tokens (in+out) a single agent run may consume before BudgetExceeded.
MAX_TOKENS_PER_AGENT_RUN=100000

# Max cumulative agent spend (USD) per calendar day before BudgetExceeded.
COST_BUDGET_DAILY_USD=25.0

# Max wall-clock seconds a single agent run may take before BudgetExceeded.
MAX_RUN_TIME_SECONDS=600

# Max resident memory (MB) a single agent run may use before BudgetExceeded.
MAX_MEMORY_MB=1024

# ------------------------------------------------------------
# FLEET OS BENCHMARK MANAGER (Day 10 — composite score + regression detection)
# ------------------------------------------------------------
# p50 latency (ms) considered "perfect" (score 1.0); 0 at 2x this value.
BENCHMARK_LATENCY_TARGET_MS=30000.0

# Composite benchmark_score weights — should sum to 1.0.
BENCHMARK_WEIGHT_LATENCY=0.15
BENCHMARK_WEIGHT_TOOL_ACCURACY=0.20
BENCHMARK_WEIGHT_VERIFICATION_COVERAGE=0.20
BENCHMARK_WEIGHT_RETRY_SUCCESS=0.15
BENCHMARK_WEIGHT_COMPILE_SUCCESS=0.15
BENCHMARK_WEIGHT_HALLUCINATION=0.15

# Fractional drop in benchmark_score vs. baseline that flags a regression.
BENCHMARK_REGRESSION_THRESHOLD=0.10
