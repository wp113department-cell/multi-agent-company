# ============================================================
# Gridiron Developer Department — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# ------------------------------------------------------------
# DATABASE (required)
# ------------------------------------------------------------
# PostgreSQL DSN. asyncpg driver required for async SQLAlchemy.
DATABASE_URL=postgresql+asyncpg://gridiron:gridiron@localhost:5432/gridiron_dev

# ------------------------------------------------------------
# ANTHROPIC API (required)
# ------------------------------------------------------------
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------
# MODEL TIERS (optional — defaults shown)
# ------------------------------------------------------------
# Haiku: router/triage/PM/Architect/Decomposer (cheap, fast)
MODEL_PLANNER=claude-haiku-4-5-20251001
# Sonnet: Coder/QA/Review (best code quality)
MODEL_CODER=claude-sonnet-5
# Haiku: heartbeat/summary/embeddings
MODEL_ROUTER=claude-haiku-4-5-20251001

# ------------------------------------------------------------
# VOYAGE AI (optional — enables semantic search)
# ------------------------------------------------------------
# Get your key at https://www.voyageai.com/
# If unset, context builder falls back to keyword-only scoring.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-code-2
VOYAGE_DIMENSIONS=1536

# ------------------------------------------------------------
# REPOSITORY INTELLIGENCE
# ------------------------------------------------------------
# Absolute path to the codebase agents will read and operate on.
TARGET_REPO_PATH=/home/pc-117/Documents/CRR2906

# Directory where per-task git worktrees are created.
WORKTREES_DIR=/tmp/gridiron-worktrees

# ------------------------------------------------------------
# PIPELINE BEHAVIOUR
# ------------------------------------------------------------
# full  = PM Agent → Architect Agent → Decomposer (LangGraph, Phase 3)
# simple = single Planner Agent (Phase 1 mode, no LangGraph)
PIPELINE_MODE=full

# Max self-correction retries before Coder marks task blocked.
MAX_RETRIES=3

# Token budget for context assembly (used by context_builder).
CONTEXT_TOKEN_BUDGET=8000

# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
DEBUG=false
